# =============================================================================
# CARDEX — Environment Variables Reference
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the actual .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Core infrastructure
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://cardex:CHANGEME@postgres:5432/cardex
REDIS_URL=redis://redis:6379
REDIS_ADDR=redis:6379
REDIS_PASS=

CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DB=cardex
CLICKHOUSE_USER=cardex
CLICKHOUSE_PASSWORD=CHANGEME

# -----------------------------------------------------------------------------
# MeiliSearch
# -----------------------------------------------------------------------------
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGEME_32_CHAR_MIN

# -----------------------------------------------------------------------------
# JWT Authentication (RS256)
# Generate with: openssl genrsa -out private.pem 4096
#                openssl rsa -in private.pem -pubout -out public.pem
# Mount as Docker secrets or set file paths below.
# -----------------------------------------------------------------------------
JWT_RS256_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
JWT_RS256_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
# Development fallback (HS256, only used when key files are absent)
JWT_DEV_SECRET=dev-secret-change-me-in-production

# -----------------------------------------------------------------------------
# Google Maps / Places API
# Required for H3 dealer discovery. Get at console.cloud.google.com
# Enable: Maps JavaScript API, Places API, Geocoding API
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# CARDEX API
# -----------------------------------------------------------------------------
PORT=8080
CORS_ORIGINS=http://localhost:3001,https://cardex.eu,https://www.cardex.eu

# -----------------------------------------------------------------------------
# Scraper / Discovery
# -----------------------------------------------------------------------------
# SPIDER_CONCURRENCY: max concurrent crawler goroutines.
# Default lowered to 8 (was 20) — prevents OOM on CX42 when Playwright
# instances (Family F) are active. Each Chromium instance ~300 MB RAM.
SPIDER_CONCURRENCY=8
# Hard cap on simultaneous Playwright/Chromium browser instances.
DISCOVERY_PLAYWRIGHT_MAX=3
DISCOVERY_COUNTRIES=ES,FR,DE,NL,BE,CH

# Quote signing (alpha engine)
QUOTE_SECRET=CHANGEME_quote_signing_secret

# -----------------------------------------------------------------------------
# Next.js Web App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_MEILI_URL=http://localhost:7700
NEXT_PUBLIC_MEILI_SEARCH_KEY=       # public search-only key (not master key!)

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGEME
PROMETHEUS_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Optional: SMTP for email alerts
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@cardex.eu

# -----------------------------------------------------------------------------
# NOTE: Automated CAPTCHA solving and residential proxy rotation are
# PERMANENTLY PROHIBITED under the CARDEX institutional policy (V6 mandate).
# See SECURITY.md §"Illegal techniques". These variables have been removed.
# If CAPTCHA pages are encountered, the URL is skipped and retried next cycle.
# -----------------------------------------------------------------------------
