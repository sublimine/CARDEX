{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CARDEX Edge",
  "version": "0.1.0",
  "identifier": "eu.cardex.edge",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "CARDEX Edge",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "CARDEX",
    "copyright": "© 2026 CARDEX",
    "shortDescription": "Push dealer inventory to CARDEX via gRPC",
    "updater": {
      "active": true,
      "endpoints": [
        "https://update.cardex.eu/edge-tauri/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_TAURI_UPDATE_PUBKEY"
    }
  }
}
