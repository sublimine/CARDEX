**/node_modules/
**/.next/
bin/
*.exe
.env
.env.*
*.log
.vscode/
.cursor/
.claude/
!.env.example

# Compiled Go binaries
*/cmd/*/discovery-service
*/cmd/*/extraction-service
*/cmd/*/quality-service

# JWT keys and certificates
secrets/
*.pem

# PDF files (binary blobs — use external document storage)
*.pdf

# Python cache
__pycache__/
*.pyc
*.pyo

# Go test artifacts
*.test
coverage.out
coverage.html

# Go workspace sum file (auto-generated, not needed in VCS)
go.work.sum

# Temporary audit files
TEMP_AUDIT.md

# Deploy environment files (explicit)
deploy/.env
deploy/.env.*
!deploy/env.example
