# Caddyfile — CARDEX reverse proxy + auto TLS
# Caddy automatically provisions Let's Encrypt certificates for the configured domain.
#
# Configuration:
#   Set CARDEX_DOMAIN env var (e.g. "cardex.io") or replace {$CARDEX_DOMAIN} below.
#   In local dev: use "localhost" — Caddy generates self-signed cert automatically.
#
# Upstream services (running as Docker containers or systemd services on loopback):
#   discovery  → http://discovery:8080  (Docker) or http://127.0.0.1:8080 (systemd)
#   extraction → http://extraction:8080
#   quality    → http://quality:8080

{$CARDEX_DOMAIN:localhost}, www.{$CARDEX_DOMAIN:localhost} {

    # ── TLS ────────────────────────────────────────────────────────
    # Caddy handles Let's Encrypt automatically (ACME HTTP-01 challenge).
    # For production: ensure port 80 is open for ACME challenge.
    tls {
        protocols tls1.3
        curves x25519
        ciphers TLS_CHACHA20_POLY1305_SHA256 TLS_AES_256_GCM_SHA384
    }

    # ── Security headers ───────────────────────────────────────────
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        X-XSS-Protection          "1; mode=block"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Permissions-Policy        "geolocation=(), camera=(), microphone=()"
        # CSP: backend API — no scripts/styles served directly (#36)
        Content-Security-Policy   "default-src 'none'; frame-ancestors 'none'"
        -Server
    }

    # ── Health endpoint ─────────────────────────────────────────────
    # Used by UptimeRobot / external monitors. Returns 200 OK.
    handle /health {
        respond "OK" 200
    }

    # ── Metrics (Prometheus) — loopback only ────────────────────────
    # Grafana/Prometheus access via SSH tunnel; block external access.
    handle /metrics* {
        @notlocal not remote_ip 127.0.0.1 ::1
        handle @notlocal {
            respond "Forbidden" 403
        }
        handle {
            reverse_proxy prometheus:9090
        }
    }

    # ── Discovery API ───────────────────────────────────────────────
    handle /api/discovery/* {
        uri strip_prefix /api/discovery
        reverse_proxy discovery:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            health_uri /healthz
            health_interval 30s
        }
    }

    # ── Extraction API ──────────────────────────────────────────────
    handle /api/extraction/* {
        uri strip_prefix /api/extraction
        reverse_proxy extraction:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            health_uri /healthz
            health_interval 30s
        }
    }

    # ── Quality API ─────────────────────────────────────────────────
    handle /api/quality/* {
        uri strip_prefix /api/quality
        reverse_proxy quality:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            health_uri /healthz
            health_interval 30s
        }
    }

    # ── Grafana (loopback / SSH tunnel only) ────────────────────────
    handle /grafana/* {
        @notlocal not remote_ip 127.0.0.1 ::1
        handle @notlocal {
            respond "Forbidden — use SSH tunnel: ssh -L 3001:localhost:3001 cardex@{$CARDEX_DOMAIN}" 403
        }
        handle {
            uri strip_prefix /grafana
            reverse_proxy grafana:3000
        }
    }

    # ── 404 fallback ────────────────────────────────────────────────
    handle {
        respond "Not Found" 404
    }

    # ── Logging ────────────────────────────────────────────────────
    log {
        output file /var/log/caddy/cardex-access.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}

# Local dev override: plain HTTP on localhost for Docker Compose
# (Caddy auto-TLS handles this, but kept for clarity)
:80 {
    redir https://{host}{uri} permanent
}
