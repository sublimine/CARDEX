# ============================================================================
# CARDEX — Environment Variables Template
# Copy this file to .env (or deploy/.env) and fill in real values.
# NEVER commit .env files — they are in .gitignore.
# ============================================================================

# ── Workspace Service ────────────────────────────────────────────────────────

# HTTP listen port (default: 8506)
WORKSPACE_PORT=8506

# SQLite database path (default: data/workspace.db)
WORKSPACE_DB_PATH=data/workspace.db

# Media storage root (default: data/workspace/media)
WORKSPACE_MEDIA_DIR=data/workspace/media

# HMAC-SHA256 JWT signing secret — generate with: openssl rand -hex 32
# REQUIRED in production. If absent, an ephemeral random value is used
# (all sessions are invalidated on restart).
CARDEX_JWT_SECRET=

# Self-registration token — POST /api/v1/auth/register requires X-Register-Token: <value>.
# If empty (default), self-registration is disabled entirely.
# Generate with: openssl rand -hex 32
REGISTER_TOKEN=

# ── SMTP (outbound email for reply engine) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Prometheus metrics listen addr for workspace service (default: :9091)
WORKSPACE_METRICS_ADDR=:9091

# ── Public API base URLs (override only for testing/proxy) ───────────────────

# NHTSA vPIC — public, no auth required (US VIN decode)
NHTSA_BASE_URL=https://vpic.nhtsa.dot.gov

# RDW Open Data — public, no auth required (NL vehicle registry)
RDW_BASE_URL=https://opendata.rdw.nl/resource

# ── Discovery Service ────────────────────────────────────────────────────────

# SQLite knowledge-graph path (default: ./data/discovery.db)
DISCOVERY_DB_PATH=./data/discovery.db

# Prometheus metrics listen addr (default: :9090)
METRICS_ADDR=:9090

# Countries to run discovery for, comma-separated ISO-3166-1 alpha-2
# Example: FR,NL,DE,BE,ES
DISCOVERY_COUNTRIES=FR

# ── INSEE Sirene API (FR company registry) ───────────────────────────────────
# Obtain an OAuth2 token at: https://portail.espace-collegue.insee.fr/
# Required for Familia A — FR sub-technique.
INSEE_TOKEN=

# Requests per minute against INSEE Sirene (default: 25, free tier limit: 30)
INSEE_RATE_PER_MIN=25

# ── KvK Zoeken API (NL Chamber of Commerce) ──────────────────────────────────
# Register at: https://developers.kvk.nl/
# Test environment base URL: https://api.kvk.nl/test/api/v2/zoeken
# If absent, keyword search is skipped; bulk density ingest still runs.
KVK_API_KEY=

# ── KBO Open Data (BE Crossroads Bank for Enterprises) ───────────────────────
# Register at: https://kbopub.economie.fgov.be/kbo-open-data
# Bulk CSV download requires a registered account.
KBO_USER=
KBO_PASS=

# ── YouTube Data API v3 (dealer channel discovery) ───────────────────────────
# GCP project: decision-iq-482214
# Enable at: https://console.cloud.google.com -> APIs & Services -> YouTube Data API v3
# If absent, L.3 is silently skipped.
YOUTUBE_API_KEY=

# ── Pappers.fr API (FR sub-jurisdiction company enrichment) ──────────────────
# Obtain at: https://www.pappers.fr/api
# If absent, unauthenticated calls are made (rate limit: 50 req/h).
PAPPERS_API_KEY=

# ── Censys v2 API (infrastructure intelligence, N.1) ─────────────────────────
# Obtain at: https://censys.io -> Account -> API Access
# If either is absent, N.1 is silently skipped.
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── Shodan API (infrastructure intelligence, N.2) ────────────────────────────
# Obtain at: https://account.shodan.io
# If absent, N.2 is silently skipped.
SHODAN_API_KEY=

# ── ViewDNS.info API (reverse IP lookup, N.4) ────────────────────────────────
# Obtain at: https://viewdns.info/api/
# If absent, N.4 is silently skipped.
VIEWDNS_API_KEY=

# ── OffeneRegister (DE company registry bulk data) ───────────────────────────
# Public bulk download — no API key required.
# Path for decompressed SQLite (default: ./data/offeneregister.db)
OFFENEREGISTER_DB_PATH=./data/offeneregister.db

# ── Discovery feature flags (skip expensive families in dev/CI) ──────────────
DISCOVERY_ONE_SHOT=false
DISCOVERY_SKIP_BROWSER=false
DISCOVERY_SKIP_FAMILY_C=false
DISCOVERY_SKIP_FAMILY_D=false
DISCOVERY_SKIP_FAMILY_E=false
DISCOVERY_SKIP_FAMILY_F=false
DISCOVERY_SKIP_FAMILY_G=false
DISCOVERY_SKIP_FAMILY_H=false
DISCOVERY_SKIP_FAMILY_I=false
DISCOVERY_SKIP_FAMILY_J=false
DISCOVERY_SKIP_FAMILY_K=false
DISCOVERY_SKIP_FAMILY_L=false
DISCOVERY_SKIP_FAMILY_M=false
DISCOVERY_SKIP_FAMILY_N=false
DISCOVERY_SKIP_FAMILY_O=false

# ── Per-family rate limit overrides (milliseconds between requests) ───────────
# DISCOVERY_RATE_LIMIT_B_MS=15000
# DISCOVERY_RATE_LIMIT_C_MS=5000

# ── Edge Push / Extraction Service ───────────────────────────────────────────
# SQLite path for edge dealer accounts (default: ./data/discovery.db)
EDGE_DB_PATH=./data/discovery.db

# ── VIES VAT Validation (public EU API) ──────────────────────────────────────
# Base URL: https://ec.europa.eu/taxation_customs/vies/rest-api
# No API key required — public EU Commission endpoint.
# Rate limit: ~50 req/min per IP.
